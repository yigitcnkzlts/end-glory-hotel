{
  "name": "end-glory-hotel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && mvn spring-boot:run",
    "build": "cd frontend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && mvn clean package",
    "start": "cd frontend && npm start",
    "install:all": "cd frontend && npm install && cd ../backend && mvn clean install",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "description": "End Glory Hotel - Full Stack Web Application",
  "keywords": [
    "hotel",
    "booking",
    "nextjs",
    "spring-boot"
  ],
  "author": "End Glory Hotel Team",
  "license": "MIT"
}
